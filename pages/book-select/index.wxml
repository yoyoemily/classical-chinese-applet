<view class="page-book-select">
  <view class="page-book-select__list">
    <block wx:for="{{books}}" wx:key="id">
      <view
        class="page-book-select__card {{!item.initialized ? 'page-book-select__card--disabled' : ''}} {{item.studyMode !== 'readonly' && currentBookId === item.id ? 'page-book-select__card--active' : ''}}"
        data-book-id="{{item.id}}"
        bindtap="onTapBook"
        hover-class="{{item.initialized ? 'page-book-select__card--hover' : ''}}"
      >
        <view class="page-book-select__corner-tag {{item.studyMode === 'readonly' ? 'page-book-select__corner-tag--read' : 'page-book-select__corner-tag--checkin'}}">
          <text>{{item.studyMode === 'readonly' ? '阅读版' : '打卡版'}}</text>
        </view>
        <view class="page-book-select__cover" style="background-color: {{item.coverColor}}">
          <text>{{item.category === 'middle_school' ? '📗' : item.category === 'high_school' ? '📕' : item.category === 'tongjia' ? '📙' : item.category === 'ancient_modern' ? '📓' : item.category === 'flexible_usage' ? '📒' : item.category === 'function' ? '📋' : '📘'}}</text>
        </view>
        <view class="page-book-select__info">
          <view class="page-book-select__title-row">
            <text class="page-book-select__name">{{item.name}}</text>
            <text wx:if="{{item.studyMode !== 'readonly' && currentBookId === item.id}}" class="page-book-select__badge">当前</text>
            <text wx:if="{{!item.initialized}}" class="page-book-select__badge-coming">待开放</text>
          </view>
          <text class="page-book-select__desc">{{item.description}} · {{item.totalWords}}词</text>
        </view>
      </view>
    </block>
  </view>
</view>
