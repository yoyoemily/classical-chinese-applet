<!-- 生词本页面 -->
<view class="page-vocabulary">
  <!-- 分类标签栏 -->
  <view class="page-vocabulary__tabs">
    <block wx:for="{{tabs}}" wx:key="key">
      <view
        class="page-vocabulary__tab {{activeTab === item.key ? 'page-vocabulary__tab--active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="onTapTab"
      >
        <text>{{item.label}}</text>
      </view>
    </block>
  </view>

  <!-- 生词列表 -->
  <view class="page-vocabulary__list" wx:if="{{!isEmpty}}">
    <block wx:for="{{words}}" wx:key="wordId">
      <view
        class="page-vocabulary__card"
        data-word-id="{{item.wordId}}"
        bindtap="onTapWord"
        hover-class="page-vocabulary__card--hover"
      >
        <!-- 左侧：大字 + 拼音 -->
        <view class="page-vocabulary__word-main">
          <text class="page-vocabulary__character">{{item.character}}</text>
        </view>

        <!-- 右侧：进度指示 + 箭头 -->
        <view class="page-vocabulary__progress-area">
          <!-- 进度圆点 -->
          <view class="page-vocabulary__dots">
            <block wx:for="{{[1,2,3,4,5]}}" wx:key="*this" wx:for-item="dot">
              <view
                class="page-vocabulary__dot {{item.progress >= dot * 20 ? 'page-vocabulary__dot--filled' : ''}}"
              ></view>
            </block>
          </view>
          <text class="page-vocabulary__progress-text">{{item.progress}}%</text>
          <text class="page-vocabulary__arrow">></text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="page-vocabulary__empty" wx:if="{{isEmpty && !loading}}">
    <text class="page-vocabulary__empty-icon">📖</text>
    <text class="page-vocabulary__empty-title">还没有学过的字</text>
    <text class="page-vocabulary__empty-subtitle">快去学习吧！</text>
  </view>

  <!-- 加载中 -->
  <view class="page-vocabulary__loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
