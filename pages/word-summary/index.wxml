<!-- 字词总结页 -->
<view class="page-word-summary">
  <scroll-view class="page-word-summary__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="page-word-summary__loading"><text>加载中...</text></view>
    <block wx:else>
      <!-- 顶部汉字卡片 -->
      <view class="page-word-summary__char-card">
        <view class="page-word-summary__char-top">
          <view class="page-word-summary__char-badge" wx:if="{{wordType}}">
            <text>{{wordType}}</text>
          </view>
          <view class="page-word-summary__char-badge page-word-summary__char-badge--type" wx:if="{{characterType}}">
            <text>{{characterType}}</text>
          </view>
          <text class="page-word-summary__freq" wx:if="{{examFrequency}}">{{examFrequency}}</text>
        </view>
        <text class="page-word-summary__character">{{character}}</text>
        <text class="page-word-summary__explanation" wx:if="{{explanation}}">{{explanation}}</text>
        <view class="page-word-summary__xp" wx:if="{{xpGained > 0}}">+{{xpGained}} XP</view>
        <image class="page-word-summary__ancient" wx:if="{{oracleForm}}" src="{{oracleForm}}" mode="widthFix" />
      </view>

      <!-- 义项列表（折叠展开） -->
      <view class="page-word-summary__section">
        <text class="page-word-summary__section-title">义项</text>
        <view class="page-word-summary__meaning-list">
          <view
            wx:for="{{meaningItems}}"
            wx:key="index"
            class="page-word-summary__meaning-item"
            data-index="{{index}}"
            bindtap="onTapMeaning"
          >
            <!-- 折叠态信息行 -->
            <view class="page-word-summary__meaning-row">
              <text class="page-word-summary__meaning-number">{{index + 1}}</text>
              <view class="page-word-summary__meaning-summary">
                <text class="page-word-summary__meaning-def-text">{{item.definition}}</text>
              </view>
              <text class="page-word-summary__meaning-arrow {{item.expanded ? 'page-word-summary__meaning-arrow--up' : ''}}">▶</text>
            </view>
            <!-- 展开详情 -->
            <view class="page-word-summary__meaning-detail" wx:if="{{item.expanded}}">
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.sentenceText}}">
                <text class="page-word-summary__meaning-detail-label">📖 例：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.sentenceText}}</text>
              </view>
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.sentenceTranslation}}">
                <text class="page-word-summary__meaning-detail-label">📝 译：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.sentenceTranslation}}</text>
              </view>
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.articleTitle}}">
                <text class="page-word-summary__meaning-detail-label">📚 出处：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.articleTitle}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="page-word-summary__bottom-placeholder"></view>
    </block>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="page-word-summary__action-bar">
    <button class="page-word-summary__btn page-word-summary__btn--primary" bindtap="onTapContinue">继续学习</button>
  </view>
</view>
