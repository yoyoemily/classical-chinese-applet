<!-- 字词总结页 -->
<view class="page-word-summary">
  <scroll-view class="page-word-summary__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="page-word-summary__loading"><text>加载中...</text></view>
    <block wx:else>
      <!-- 顶部汉字卡片 -->
      <view class="page-word-summary__char-card">
        <view class="page-word-summary__char-top">
          <view class="page-word-summary__char-badge" wx:if="{{wordType}}">
            <text>{{wordType}}</text>
          </view>
          <view class="page-word-summary__char-badge page-word-summary__char-badge--type" wx:if="{{characterType}}">
            <text>{{characterType}}</text>
          </view>
          <text class="page-word-summary__freq" wx:if="{{examFrequency}}">{{examFrequency}}</text>
        </view>
        <text class="page-word-summary__character">{{character}}</text>
        <text class="page-word-summary__explanation" wx:if="{{explanation}}">{{explanation}}</text>
        <image class="page-word-summary__ancient" wx:if="{{oracleForm}}" src="{{oracleForm}}" mode="widthFix" />
      </view>

      <!-- 义项列表（折叠展开） -->
      <view class="page-word-summary__section">
        <text class="page-word-summary__section-title">义项</text>
        <view class="page-word-summary__meaning-list">
          <view
            wx:for="{{meaningItems}}"
            wx:key="index"
            class="page-word-summary__meaning-item"
            data-index="{{index}}"
            bindtap="onTapMeaning"
          >
            <!-- 折叠态信息行 -->
            <view class="page-word-summary__meaning-row">
              <text class="page-word-summary__meaning-number">{{index + 1}}</text>
              <view class="page-word-summary__meaning-summary">
                <text class="page-word-summary__meaning-pinyin-line" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
                <text> · </text>
                <text class="page-word-summary__meaning-def-text">{{item.definition}}</text>
              </view>
              <text class="page-word-summary__meaning-arrow {{item.expanded ? 'page-word-summary__meaning-arrow--up' : ''}}">▶</text>
            </view>
            <!-- 展开详情 -->
            <view class="page-word-summary__meaning-detail" wx:if="{{item.expanded}}">
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.example}}">
                <text class="page-word-summary__meaning-detail-label">📖 例：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.example}}</text>
              </view>
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.translation}}">
                <text class="page-word-summary__meaning-detail-label">📝 译：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.translation}}</text>
              </view>
              <view class="page-word-summary__meaning-detail-item" wx:if="{{item.source}}">
                <text class="page-word-summary__meaning-detail-label">📚 出处：</text>
                <text class="page-word-summary__meaning-detail-text">{{item.source}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="page-word-summary__bottom-placeholder"></view>
    </block>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="page-word-summary__action-bar">
    <view class="page-word-summary__feedback-link" bindtap="onTapFeedback">
      <text>⚠️ 反馈错误</text>
    </view>
    <button class="page-word-summary__btn page-word-summary__btn--primary" bindtap="onTapContinue">继续学习</button>
  </view>

  <!-- 错误反馈浮层 -->
  <view class="page-word-summary__feedback-mask" wx:if="{{showFeedbackPanel}}" bindtap="onCloseFeedback"></view>
  <view class="page-word-summary__feedback-panel {{showFeedbackPanel ? 'page-word-summary__feedback-panel--show' : ''}}">
    <view class="page-word-summary__feedback-header">
      <text class="page-word-summary__feedback-title">🙋 反馈错误</text>
      <view class="page-word-summary__feedback-close" bindtap="onCloseFeedback">
        <text>✕</text>
      </view>
    </view>

    <view class="page-word-summary__feedback-body">
      <view class="page-word-summary__feedback-label">错误类型</view>
      <view class="page-word-summary__feedback-categories">
        <view
          wx:for="{{['definition','source','other']}}"
          wx:key="*this"
          wx:for-item="cat"
          class="page-word-summary__feedback-cat {{feedbackCategory === cat ? 'page-word-summary__feedback-cat--active' : ''}}"
          data-category="{{cat}}"
          bindtap="onSelectFeedbackCategory"
        >
          <text wx:if="{{cat === 'definition'}}">释义有误</text>
          <text wx:elif="{{cat === 'source'}}">出处有误</text>
          <text wx:else>其他</text>
        </view>
      </view>

      <view class="page-word-summary__feedback-label">详细说明（选填）</view>
      <textarea
        class="page-word-summary__feedback-textarea"
        placeholder="请描述具体哪里有问题..."
        value="{{feedbackDescription}}"
        maxlength="200"
        bindinput="onFeedbackDescriptionInput"
      />

      <view class="page-word-summary__feedback-submit-wrap">
        <view class="page-word-summary__feedback-submit {{feedbackSubmitting ? 'page-word-summary__feedback-submit--loading' : ''}}" bindtap="onSubmitFeedback">
          <text>{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
