<!-- 选篇阅读页 -->
<view class="page-article-reader">
  <block wx:if="{{loading}}">
    <view class="page-article-reader__loading"><text>加载中...</text></view>
  </block>
  <block wx:elif="{{article}}">
    <!-- 顶部头图 -->
    <view class="page-article-reader__header">
      <view class="page-article-reader__header-top">
        <!-- 左：喇叭 -->
        <view
          class="page-article-reader__audio-btn {{audioPlaying ? 'page-article-reader__audio-btn--playing' : ''}} {{audioLoading ? 'page-article-reader__audio-btn--loading' : ''}}"
          bindtap="onTapAudio"
          hover-class="page-article-reader__audio-btn--hover"
        >
          <text wx:if="{{audioLoading}}">⏳</text>
          <text wx:elif="{{audioPlaying}}">🔉</text>
          <text wx:else>🔊</text>
        </view>
        <!-- 中：标题 -->
        <view
          class="page-article-reader__title {{article.background ? 'page-article-reader__title--link' : ''}}"
          bindtap="{{article.background ? 'onTapBackground' : ''}}"
        >
          <text>《{{article.title}}》</text>
        </view>
        <!-- 右：纠错 -->
        <view class="page-article-reader__feedback-icon" bindtap="onTapFeedback">
          <text>⚠️</text>
        </view>
      </view>
      <view class="page-article-reader__meta">
        <text>{{article.author}}</text>
        <text> · {{article.dynasty}}</text>
      </view>
    </view>

    <!-- 三模式切换栏 -->
    <view class="page-article-reader__mode-bar">
      <view
        class="page-article-reader__mode-tab {{readingMode === 'plain' ? 'page-article-reader__mode-tab--active' : ''}}"
        data-mode="plain"
        bindtap="onSwitchMode"
      >
        <text>通篇阅读</text>
      </view>
      <view
        class="page-article-reader__mode-tab {{readingMode === 'sentence' ? 'page-article-reader__mode-tab--active' : ''}}"
        data-mode="sentence"
        bindtap="onSwitchMode"
      >
        <text>逐句释义</text>
      </view>
      <view
        class="page-article-reader__mode-tab {{readingMode === 'glossary' ? 'page-article-reader__mode-tab--active' : ''}}"
        data-mode="glossary"
        bindtap="onSwitchMode"
      >
        <text>典故注释</text>
      </view>
    </view>

    <!-- ============================================= -->
    <!-- 模式一：通篇阅读（原文，段落可展开译文，生词高亮可点击）   -->
    <!-- ============================================= -->
    <scroll-view
      wx:if="{{readingMode === 'plain'}}"
      class="page-article-reader__body"
      scroll-y enhanced show-scrollbar="{{false}}"
    >
      <block wx:for="{{article.sentences}}" wx:key="*this" wx:for-item="s" wx:for-index="si">
        <!-- 原文段落：可点击展开/收起 -->
        <view
          class="page-article-reader__plain-para {{expandedStates[si] ? 'page-article-reader__plain-para--expanded' : ''}}"
          data-index="{{si}}"
          bindtap="onTapSentence"
          hover-class="page-article-reader__plain-para--hover"
        >
          <view class="page-article-reader__plain-text">
            <block wx:for="{{vocabSegments[si]}}" wx:key="*this" wx:for-item="seg">
              <!-- 生词：高亮可点击 -->
              <text
                wx:if="{{seg.isKeyword}}"
                class="page-article-reader__vocab-word"
                data-word="{{seg.word}}"
                data-definition="{{seg.definition}}"
                catchtap="onTapVocabWord"
                hover-class="page-article-reader__vocab-word--hover"
              >{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-article-reader__pinyin">({{seg.pinyin}})</text></text>
              <!-- 普通文本 -->
              <text wx:else>{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-article-reader__pinyin">({{seg.pinyin}})</text></text>
            </block>
          </view>
          <text class="page-article-reader__plain-arrow">{{expandedStates[si] ? '▾' : '▸'}}</text>
        </view>
        <!-- 展开：仅展示译文 -->
        <view class="page-article-reader__plain-expand" wx:if="{{expandedStates[si]}}">
          <view class="page-article-reader__plain-trans"><text>{{s.translation}}</text></view>
        </view>
      </block>
      <view class="page-article-reader__body-spacer"></view>
    </scroll-view>

    <!-- ============================================= -->
    <!-- 模式二：逐句释义（按子句拆分，点击展开/收起译文）         -->
    <!-- ============================================= -->
    <scroll-view
      wx:elif="{{readingMode === 'sentence'}}"
      class="page-article-reader__body"
      scroll-y enhanced show-scrollbar="{{false}}"
    >
      <block wx:for="{{clauses}}" wx:key="*this" wx:for-item="cl" wx:for-index="ci">
        <view
          class="page-article-reader__clause {{clauseExpandedStates[ci] ? 'page-article-reader__clause--expanded' : ''}}"
          data-clause-index="{{ci}}"
          bindtap="onTapClause"
          hover-class="page-article-reader__clause--hover"
        >
          <view class="page-article-reader__clause-head">
            <text class="page-article-reader__clause-text">{{cl.text}}。</text>
            <text class="page-article-reader__clause-arrow">{{clauseExpandedStates[ci] ? '▾' : '▸'}}</text>
          </view>
        </view>
        <view class="page-article-reader__clause-trans" wx:if="{{clauseExpandedStates[ci]}}">
          <text>{{cl.translation}}</text>
        </view>
      </block>
      <view class="page-article-reader__body-spacer"></view>
    </scroll-view>

    <!-- ============================================= -->
    <!-- 模式三：典故注释（文中文化背景词高亮可点击）             -->
    <!-- ============================================= -->
    <scroll-view
      wx:else
      class="page-article-reader__body"
      scroll-y enhanced show-scrollbar="{{false}}"
    >
      <!-- 逐句 -->
      <block wx:for="{{glossarySegments}}" wx:key="*this" wx:for-item="segArr" wx:for-index="si">
        <view class="page-article-reader__gloss-block">
          <!-- 段切分行：glossary 词高亮 -->
          <view class="page-article-reader__gloss-line">
            <block wx:for="{{segArr}}" wx:key="*this" wx:for-item="seg">
              <text
                wx:if="{{seg.isGlossary}}"
                class="page-article-reader__gloss-word"
                data-sentence-index="{{si}}"
                data-word="{{seg.word}}"
                data-definition="{{seg.definition}}"
                bindtap="onTapGlossary"
                hover-class="page-article-reader__gloss-word--hover"
              >{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-article-reader__pinyin">({{seg.pinyin}})</text></text>
              <text wx:else>{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-article-reader__pinyin">({{seg.pinyin}})</text></text>
            </block>
          </view>

          <!-- 释义气泡 -->
          <view
            wx:if="{{glossaryPopup && glossaryPopup.sentenceIndex === si}}"
            class="page-article-reader__gloss-bubble"
          >
            <text class="page-article-reader__gloss-bubble-word">{{glossaryPopup.word}}</text>
            <text class="page-article-reader__gloss-bubble-def">{{glossaryPopup.definition}}</text>
          </view>

          <!-- 全句译文 -->
          <view class="page-article-reader__gloss-trans">
            <text>{{article.sentences[si].translation}}</text>
          </view>
        </view>
      </block>

      <!-- 底部遮罩（点击任意位置关闭释义） -->
      <view
        wx:if="{{glossaryPopup}}"
        class="page-article-reader__gloss-mask"
        bindtap="onDismissGlossary"
      ></view>

      <view class="page-article-reader__body-spacer"></view>
    </scroll-view>

    <!-- 底部安全区占位 -->
    <view class="page-article-reader__safe-bottom"></view>

    <!-- 创作背景弹窗 -->
    <view class="page-article-reader__bg-overlay" wx:if="{{showBackground}}" bindtap="onCloseBackground">
      <view class="page-article-reader__bg-modal" catchtap="">
        <view class="page-article-reader__bg-header">
          <text class="page-article-reader__bg-title">背景介绍</text>
          <view class="page-article-reader__bg-close" bindtap="onCloseBackground">
            <text>✕</text>
          </view>
        </view>
        <scroll-view class="page-article-reader__bg-body" scroll-y enhanced show-scrollbar="{{false}}">
          <text class="page-article-reader__bg-text">{{article.background}}</text>
        </scroll-view>
      </view>
    </view>

    <!-- 内联生词释义弹窗 -->
    <view class="page-article-reader__vocab-overlay" wx:if="{{vocabPopup}}" bindtap="onDismissVocabPopup">
      <view class="page-article-reader__vocab-card" catchtap="">
        <view class="page-article-reader__vocab-card-header">
          <text class="page-article-reader__vocab-card-word">{{vocabPopup.word}}</text>
        </view>
        <view class="page-article-reader__vocab-card-body">
          <text class="page-article-reader__vocab-card-def">{{vocabPopup.definition}}</text>
        </view>
        <view class="page-article-reader__vocab-card-tip">
          <text>轻触空白处关闭</text>
        </view>
      </view>
    </view>

    <!-- 错误反馈浮层 -->
    <view class="page-article-reader__feedback-mask" wx:if="{{showFeedbackPanel}}" bindtap="onCloseFeedback"></view>
    <view class="page-article-reader__feedback-panel {{showFeedbackPanel ? 'page-article-reader__feedback-panel--show' : ''}}">
      <view class="page-article-reader__feedback-header">
        <text class="page-article-reader__feedback-title">🙋 反馈错误</text>
        <view class="page-article-reader__feedback-close" bindtap="onCloseFeedback">
          <text>✕</text>
        </view>
      </view>

      <view class="page-article-reader__feedback-body">
        <view class="page-article-reader__feedback-label">错误类型</view>
        <view class="page-article-reader__feedback-categories">
          <view
            wx:for="{{['sentence_text','translation','annotation','article_info','other']}}"
            wx:key="*this"
            wx:for-item="cat"
            class="page-article-reader__feedback-cat {{feedbackCategory === cat ? 'page-article-reader__feedback-cat--active' : ''}}"
            data-category="{{cat}}"
            bindtap="onSelectFeedbackCategory"
          >
            <text wx:if="{{cat === 'sentence_text'}}">原文有误</text>
            <text wx:elif="{{cat === 'translation'}}">译文有误</text>
            <text wx:elif="{{cat === 'annotation'}}">标注有误</text>
            <text wx:elif="{{cat === 'article_info'}}">文章信息有误</text>
            <text wx:else>其他</text>
          </view>
        </view>

        <view class="page-article-reader__feedback-label">详细说明（选填）</view>
        <textarea
          class="page-article-reader__feedback-textarea"
          placeholder="请描述具体哪里有问题..."
          value="{{feedbackDescription}}"
          maxlength="200"
          bindinput="onFeedbackDescriptionInput"
        />

        <view class="page-article-reader__feedback-submit-wrap">
          <view class="page-article-reader__feedback-submit {{feedbackSubmitting ? 'page-article-reader__feedback-submit--loading' : ''}}" bindtap="onSubmitFeedback">
            <text>{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
