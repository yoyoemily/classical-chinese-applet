<!-- 我的 / 个人中心页面 -->
<view class="page-mine">
  <!-- 用户头部卡片 -->
  <view class="page-mine__header">
    <view class="page-mine__header-card">
      <!-- 头像 -->
      <view
        class="page-mine__avatar"
        data-url="/pages/profile-edit/index"
        bindtap="onTapMenuItem"
      >
        <image
          wx:if="{{avatarUrl}}"
          class="page-mine__avatar-img"
          src="{{avatarUrl}}"
          mode="aspectFill"
        />
        <text wx:else class="page-mine__avatar-icon">👤</text>
      </view>

      <!-- 用户信息 -->
      <view class="page-mine__user-info" data-url="/pages/profile-edit/index" bindtap="onTapMenuItem">
        <view class="page-mine__name-row">
          <text class="page-mine__username">{{userName}}</text>
        </view>
        <view class="page-mine__level-row">
          <text class="page-mine__level-tag" catch:tap="onTapLevel">Lv.{{level}} {{title}}</text>
          <view
            wx:if="{{memberLevel >= 1}}"
            class="page-mine__nuo-badge"
            catch:tap="onTapNuoBadge"
            hover-class="page-mine__nuo-badge--active"
          >契约会员</view>
        </view>
      </view>

      <!-- 勋章入口 -->
      <view class="page-mine__badge-entry" bindtap="onTapBadges">
        <text class="page-mine__badge-icon">🏅</text>
        <text class="page-mine__badge-count">{{badgeCount}}/{{totalBadges}}</text>
      </view>
    </view>

    <!-- 勋章进度条 -->
    <view wx:if="{{nextBadge}}" class="page-mine__badge-progress">
      <view class="page-mine__badge-progress-header">
        <view class="page-mine__badge-progress-left">
          <text class="page-mine__badge-progress-icon">{{nextBadge.icon}}</text>
          <text class="page-mine__badge-progress-name">{{nextBadge.name}}</text>
        </view>
        <text class="page-mine__badge-progress-gap">
          <block wx:if="{{nextBadge.gap === 0}}">即将获得</block>
          <block wx:else>还差 {{nextBadge.gap}} 天</block>
        </text>
      </view>
      <view class="page-mine__badge-progress-bar">
        <view
          class="page-mine__badge-progress-fill"
          style="width: {{nextBadge.percent}}%;"
        ></view>
      </view>
    </view>
  </view>

  <!-- 分享按钮 -->
  <view class="page-mine__share">
    <view class="page-mine__share-btn" bindtap="onTapShare">
      <text class="page-mine__share-icon">📤</text>
      <text class="page-mine__share-label">分享给朋友</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="page-mine__menu">
    <block wx:for="{{menuItems}}" wx:key="key">
      <view
        class="page-mine__menu-item"
        data-url="{{item.url}}"
        bindtap="onTapMenuItem"
        hover-class="page-mine__menu-item--hover"
      >
        <view class="page-mine__menu-left">
          <text class="page-mine__menu-icon">{{item.icon}}</text>
          <text class="page-mine__menu-label">{{item.label}}</text>
        </view>
        <view class="page-mine__menu-right">
          <text
            wx:if="{{item.suffix}}"
            class="page-mine__menu-suffix"
          >{{item.suffix}}</text>
          <text class="page-mine__menu-arrow">></text>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部信息 -->
  <view class="page-mine__footer">
    <text class="page-mine__footer-text">文言雀</text>
  </view>

  <!-- 分享海报弹窗 -->
  <view class="page-mine__poster-overlay" wx:if="{{showSharePoster}}" bindtap="{{shareConfirmed ? '' : 'onCloseShare'}}">
    <view class="page-mine__poster-modal" catchtap="noop">
      <view class="page-mine__poster-close" wx:if="{{!shareConfirmed}}" bindtap="onCloseShare">✕</view>

      <!-- 阶段一：海报 + 操作按钮 -->
      <block wx:if="{{!shareConfirmed}}">
        <image
          class="page-mine__poster-image"
          src="{{posterTempPath}}"
          mode="widthFix"
        />
        <view class="page-mine__poster-actions">
          <view class="page-mine__poster-btn-row">
            <button class="page-mine__poster-save" bindtap="onSavePoster">保存图片</button>
            <button
              wx:if="{{memberLevel < 1}}"
              class="page-mine__poster-btn-row-link {{posterSaved ? '' : 'page-mine__poster-btn-row-link--disabled'}}"
              bindtap="onConfirmShare"
              disabled="{{!posterSaved}}"
            >我要分享</button>
          </view>
        </view>
      </block>

      <!-- 阶段二：签订契约（替换海报） -->
      <view class="page-mine__poster-trust" wx:else>
        <text class="page-mine__poster-trust-icon">📜</text>
        <text class="page-mine__poster-trust-title">金石契</text>
        <text class="page-mine__poster-trust-text">君以分享托付文言雀</text>
        <text class="page-mine__poster-trust-text">文言雀亦以赤诚报君</text>
        <text class="page-mine__poster-trust-text page-mine__poster-trust-text--pact">此约既成，金石不渝</text>
        <!-- 签订契约复选框 -->
        <view class="page-mine__poster-trust-check" bindtap="onTogglePactCheck">
          <text class="page-mine__poster-trust-check-finger">👉</text>
          <view class="page-mine__poster-trust-check-box {{pactChecked ? 'page-mine__poster-trust-check-box--checked' : ''}}">
            <text wx:if="{{pactChecked}}" class="page-mine__poster-trust-check-mark">✓</text>
          </view>
          <text class="page-mine__poster-trust-check-label">余今签契，行之以诚</text>
        </view>
        <button
          class="page-mine__poster-trust-btn {{pactChecked ? '' : 'page-mine__poster-trust-btn--disabled'}}"
          bindtap="onConfirmPact"
          disabled="{{!pactChecked}}"
        >签订契约</button>
        <text class="page-mine__poster-trust-footer">契约既签，永久免费学习</text>
      </view>
    </view>
  </view>

  <!-- 契约会员弹窗 -->
  <view class="page-mine__nuo-overlay" wx:if="{{showNuoDialog}}" bindtap="onCloseNuoDialog">
    <view class="page-mine__nuo-modal" catchtap="noop">
      <view class="page-mine__nuo-modal-close" bindtap="onCloseNuoDialog">✕</view>
      <view class="page-mine__nuo-modal-seal">契</view>
      <text class="page-mine__nuo-modal-icon">📜</text>
      <text class="page-mine__nuo-modal-title">金石契</text>
      <text class="page-mine__nuo-modal-text">君以分享托付文言雀</text>
      <text class="page-mine__nuo-modal-text">文言雀亦以赤诚报君</text>
      <text class="page-mine__nuo-modal-text page-mine__nuo-modal-text--pact">此约既成，金石不渝</text>
      <text class="page-mine__nuo-modal-footer">您已签订契约，永久免费学习</text>
    </view>
  </view>
</view>
