<!-- 学习核心页面 -->
<view class="page-study">

  <!-- ==================== 前置步骤：从句子中识别目标字 ==================== -->
  <block wx:if="{{screen === 'preStep'}}">
    <view class="page-study__header">
      <view class="page-study__dots">
        <view wx:for="{{dotsArray}}" wx:key="*this" class="page-study__dot {{index < completedWords ? 'page-study__dot--filled' : ''}}"></view>
        <text wx:if="{{totalWords > 10}}" class="page-study__dots-extra">+{{totalWords - 10}}</text>
      </view>
      <view class="page-study__meta">
        <text class="page-study__mode">{{modeLabel}}</text>
        <text class="page-study__counter">{{completedWords + 1}}/{{totalWords}} 个词</text>
      </view>
    </view>

    <view class="page-study__body">
      <!-- 句子展示 -->
      <view class="page-study__sentence-area">
        <text class="page-study__sentence-text">{{currentSentence.text}}</text>
        <view class="page-study__sentence-source {{currentSentence.articleId ? 'page-study__sentence-source--link' : ''}}" wx:if="{{currentSentence.source}}" bindtap="onTapFullText">
          <text>—— {{currentSentence.source}} <text wx:if="{{currentSentence.articleId}}" class="page-study__sentence-source-arrow">→</text></text>
        </view>
      </view>

      <!-- 题干提示 -->
      <view class="page-study__prestep-prompt">
        <text>{{preStepPrompt}}</text>
      </view>

      <!-- 字符选择网格 -->
      <view class="page-study__char-grid">
        <view wx:for="{{charOptions}}" wx:key="*this"
          class="page-study__char-cell
            {{showPreStepCorrect && item === preStepCorrectChar ? 'page-study__char-cell--correct' : ''}}
            {{showPreStepWrong && item === preStepSelectedChar ? 'page-study__char-cell--wrong' : ''}}"
          data-char="{{item}}" bindtap="onSelectPreChar"
          hover-class="page-study__char-cell--hover">
          <text>{{item}}</text>
        </view>
      </view>

      <!-- 错误提示 -->
      <view class="page-study__prestep-hint" wx:if="{{showPreStepWrong}}">
        <text>不对，再试一次</text>
      </view>

      <!-- 正确提示 -->
      <view class="page-study__prestep-success" wx:if="{{showPreStepCorrect}}">
        <text class="page-study__prestep-success-icon">✓</text>
        <text>正确！</text>
      </view>
    </view>
  </block>

  <!-- 问答视图 -->
  <block wx:if="{{screen === 'question'}}">
    <!-- 顶部进度 -->
    <view class="page-study__header">
      <view class="page-study__dots">
        <view wx:for="{{dotsArray}}" wx:key="*this" class="page-study__dot {{index < completedWords ? 'page-study__dot--filled' : ''}}"></view>
        <text wx:if="{{totalWords > 10}}" class="page-study__dots-extra">+{{totalWords - 10}}</text>
      </view>
      <view class="page-study__meta">
        <text class="page-study__mode">{{modeLabel}}</text>
        <text class="page-study__counter">{{completedWords + 1}}/{{totalWords}} 个词</text>
      </view>
    </view>

    <!-- 主体 -->
    <view class="page-study__body">
      <view class="page-study__audio-btn {{audioPlaying ? 'page-study__audio-btn--playing' : ''}} {{audioLoading ? 'page-study__audio-btn--loading' : ''}}" bindtap="onTapAudio" hover-class="page-study__audio-btn--hover">
        <text wx:if="{{audioLoading}}">⏳</text>
        <text wx:elif="{{audioPlaying}}">🔉</text>
        <text wx:else>🔊</text>
      </view>

      <!-- 句子展示 -->
      <view class="page-study__sentence-area">
        <view class="page-study__sentence-text">
          <text>{{sentencePrefix}}</text>
          <text class="page-study__sentence-target">{{sentenceTarget}}</text>
          <text>{{sentenceSuffix}}</text>
        </view>
        <view class="page-study__sentence-source {{currentSentence.articleId ? 'page-study__sentence-source--link' : ''}}" wx:if="{{currentSentence.source}}" bindtap="onTapFullText">
          <text>—— {{currentSentence.source}} <text wx:if="{{currentSentence.articleId}}" class="page-study__sentence-source-arrow">→</text></text>
        </view>
      </view>

      <!-- 题干 -->
      <view class="page-study__question">
        <text>句中"<text class="page-study__target-word">{{currentWord}}</text>"<text wx:if="{{currentWordType}}">（{{currentWordType}}）</text>的意思是？</text>
      </view>

      <!-- 选项 -->
      <view class="page-study__options">
        <view
          wx:for="{{options}}" wx:key="*this"
          class="page-study__option {{showCorrect && index === correctIndex ? 'page-study__option--correct' : ''}} {{showWrong && index === selectedIndex ? 'page-study__option--wrong' : ''}} {{showWrong && index === correctIndex ? 'page-study__option--correct' : ''}}"
          data-index="{{index}}"
          bindtap="onSelectOption"
          hover-class="page-study__option--hover"
        >
          <view class="page-study__option-label">{{index === 0 ? 'A' : (index === 1 ? 'B' : (index === 2 ? 'C' : 'D'))}}</view>
          <view class="page-study__option-text">{{item}}</view>
        </view>
      </view>

      <!-- 不知道按钮 —— 卡片化，鼓励用户诚实选择 -->
      <view class="page-study__dont-know-card" bindtap="onTapDontKnow" hover-class="page-study__dont-know-card--hover">
        <view class="page-study__dont-know-icon">🤔</view>
        <view class="page-study__dont-know-body">
          <text class="page-study__dont-know-title">不知道</text>
          <text class="page-study__dont-know-hint">拿不准就点这里，乱选没有意义</text>
        </view>
        <view class="page-study__dont-know-badge">推荐</view>
      </view>
    </view>

    <!-- 正确闪动 -->
    <view class="page-study__flash-overlay" wx:if="{{showCorrect}}">
      <view class="page-study__flash-icon-wrap">
        <text class="page-study__flash-icon">✓</text>
      </view>
    </view>
  </block>

  <!-- 纠错视图 -->
  <block wx:if="{{screen === 'correction'}}">
    <view class="page-study__header">
      <view class="page-study__dots">
        <view wx:for="{{dotsArray}}" wx:key="*this" class="page-study__dot {{index < completedWords ? 'page-study__dot--filled' : ''}}"></view>
      </view>
      <view class="page-study__meta">
        <text class="page-study__mode">{{modeLabel}}</text>
        <text class="page-study__counter">{{completedWords + 1}}/{{totalWords}} 个词</text>
      </view>
    </view>

    <view class="page-study__body page-study__body--correction">
      <view class="page-study__corr-sentence">
        <text class="page-study__corr-sentence-text">{{sentenceText}}</text>
      </view>

      <view class="page-study__sentence-source {{currentSentence.articleId ? 'page-study__sentence-source--link' : ''}}" wx:if="{{currentSentence.source}}" bindtap="onTapFullText">
        <text>—— {{currentSentence.source}} <text wx:if="{{currentSentence.articleId}}" class="page-study__sentence-source-arrow">→</text></text>
      </view>

      <view class="page-study__corr-translation">
        <text class="page-study__corr-translation-label">译文</text>
        <text class="page-study__corr-translation-text">{{sentenceTranslation}}</text>
      </view>

      <view class="page-study__corr-cards">
        <view class="page-study__corr-card page-study__corr-card--wrong">
          <view class="page-study__corr-card-header">
            <text class="page-study__corr-card-icon">✗</text>
            <text class="page-study__corr-card-label">你的回答</text>
          </view>
          <text class="page-study__corr-card-value">{{userAnswer}}</text>
        </view>
        <view class="page-study__corr-card page-study__corr-card--right">
          <view class="page-study__corr-card-header">
            <text class="page-study__corr-card-icon page-study__corr-card-icon--success">✓</text>
            <text class="page-study__corr-card-label">正确答案</text>
          </view>
          <text class="page-study__corr-card-value">{{correctAnswer}}</text>
        </view>
      </view>

      <view class="page-study__corr-mnemonic" wx:if="{{mnemonic}}">
        <view class="page-study__corr-mnemonic-header">
          <text>💡</text>
          <text>记忆提示</text>
        </view>
        <text class="page-study__corr-mnemonic-text">{{mnemonic}}</text>
      </view>

      <view class="page-study__corr-actions">
        <view class="page-study__corr-btn" bindtap="onCorrectionContinue" hover-class="page-study__corr-btn--hover">
          <text>继续</text>
        </view>
      </view>

      <!-- 错误反馈入口 -->
      <view class="page-study__feedback-entry" bindtap="onTapFeedback">
        <text>⚠️ 内容有误？我要反馈</text>
      </view>
    </view>
  </block>

  <!-- 错误反馈浮层 -->
  <view class="page-study__feedback-mask" wx:if="{{showFeedbackPanel}}" bindtap="onCloseFeedback"></view>
  <view class="page-study__feedback-panel {{showFeedbackPanel ? 'page-study__feedback-panel--show' : ''}}">
    <view class="page-study__feedback-header">
      <text class="page-study__feedback-title">🙋 反馈错误</text>
      <view class="page-study__feedback-close" bindtap="onCloseFeedback">
        <text>✕</text>
      </view>
    </view>

    <view class="page-study__feedback-body">
      <!-- 错误类别 -->
      <view class="page-study__feedback-label">错误类型</view>
      <view class="page-study__feedback-categories">
        <view
          wx:for="{{['sentence_text','translation','definition','source','other']}}"
          wx:key="*this"
          wx:for-item="cat"
          class="page-study__feedback-cat {{feedbackCategory === cat ? 'page-study__feedback-cat--active' : ''}}"
          data-category="{{cat}}"
          bindtap="onSelectFeedbackCategory"
        >
          <text wx:if="{{cat === 'sentence_text'}}">原文有误</text>
          <text wx:elif="{{cat === 'translation'}}">译文有误</text>
          <text wx:elif="{{cat === 'definition'}}">释义有误</text>
          <text wx:elif="{{cat === 'source'}}">出处有误</text>
          <text wx:else>其他</text>
        </view>
      </view>

      <!-- 详细说明 -->
      <view class="page-study__feedback-label">详细说明（选填）</view>
      <textarea
        class="page-study__feedback-textarea"
        placeholder="请描述具体哪里有问题..."
        value="{{feedbackDescription}}"
        maxlength="200"
        bindinput="onFeedbackDescriptionInput"
      />

      <view class="page-study__feedback-submit-wrap">
        <view class="page-study__feedback-submit {{feedbackSubmitting ? 'page-study__feedback-submit--loading' : ''}}" bindtap="onSubmitFeedback">
          <text>{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
