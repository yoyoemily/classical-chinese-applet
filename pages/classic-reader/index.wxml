<!-- 经典阅读页 v2 支持 full/chunked + strip/list/accordion/author -->
<view class="page-classic-reader">
  <!-- 加载态 -->
  <block wx:if="{{loading}}">
    <view class="page-classic-reader__loading">
      <text class="page-classic-reader__loading-text">开卷中...</text>
    </view>
  </block>

  <block wx:elif="{{meta}}">
    <!-- 顶部标题区 -->
    <view class="page-classic-reader__header">
      <!-- 第一行：左喇叭 · 中书/篇名 · 右纠错 -->
      <view class="page-classic-reader__header-top">
        <!-- 左：喇叭 -->
        <view
          class="page-classic-reader__audio-btn {{audioPlaying ? 'page-classic-reader__audio-btn--playing' : ''}} {{audioLoading ? 'page-classic-reader__audio-btn--loading' : ''}}"
          bindtap="onTapAudio"
          hover-class="page-classic-reader__audio-btn--hover"
        >
          <text wx:if="{{audioLoading}}">⏳</text>
          <text wx:elif="{{audioPlaying}}">🔉</text>
          <text wx:else>🔊</text>
        </view>
        <!-- 中：书名 / 篇名 -->
        <view
          class="page-classic-reader__title {{currentContent.background ? 'page-classic-reader__title--link' : ''}}"
          bindtap="{{currentContent.background ? 'onTapBackground' : ''}}"
        >
          <!-- 选集型：有篇章作者时显示篇名 -->
          <text wx:if="{{chapterAuthor}}">《{{currentContent.title}}》</text>
          <!-- 章节型：无篇章作者时显示书名（保持现状） -->
          <text wx:else>《{{meta.name}}》</text>
        </view>
        <!-- 右：纠错 -->
        <view class="page-classic-reader__feedback-icon" bindtap="onTapFeedback">
          <text>⚠️</text>
        </view>
      </view>
      <!-- 第二行：左章节导航 · 中作者朝代 · 右占位（对齐第一行纠错图标） -->
      <view class="page-classic-reader__header-meta">
        <!-- 左：章节导航 -->
        <view class="page-classic-reader__toc-btn" bindtap="onToggleToc">
          <text>☰</text>
        </view>
        <!-- 中：作者 · 朝代 -->
        <block wx:if="{{chapterAuthor}}">
          <text class="page-classic-reader__meta-text">{{chapterEra}} · {{chapterAuthor}}</text>
        </block>
        <block wx:else>
          <text class="page-classic-reader__meta-text">{{meta.author}} · {{meta.era}}</text>
        </block>
        <!-- 右：占位（保持左中右三栏对齐） -->
        <view class="page-classic-reader__meta-spacer"></view>
      </view>
    </view>

    <!-- strip 导航条（仅 strip 模式 + 条目 ≤ 20 时显示） -->
    <scroll-view
      wx:if="{{meta.navMode === 'strip' && tocNodes.length > 0}}"
      class="page-classic-reader__strip-nav"
      scroll-x enhanced show-scrollbar="{{false}}"
    >
      <block wx:for="{{tocNodes}}" wx:key="id">
        <view
          class="page-classic-reader__strip-item {{currentNodeId === item.id ? 'page-classic-reader__strip-item--active' : ''}} {{!item.isLeaf ? 'page-classic-reader__strip-item--disabled' : ''}}"
          data-node-id="{{item.id}}"
          data-is-leaf="{{item.isLeaf}}"
          bindtap="onTapStripNode"
        >
          <text>{{item.title}}</text>
          <text wx:if="{{item.isLeaf}}" class="page-classic-reader__toc-dot {{listenedNodeIds[item.id] ? 'page-classic-reader__toc-dot--listened' : 'page-classic-reader__toc-dot--fresh'}}">{{listenedNodeIds[item.id] ? '●' : '○'}}</text>
        </view>
      </block>
    </scroll-view>

    <!-- ========================================== -->
    <!-- full 加载模式：连续滚动正文 -->
    <!-- ========================================== -->
    <scroll-view
      wx:if="{{meta.loadMode === 'full' && fullChapters.length > 0}}"
      class="page-classic-reader__scroll-body"
      scroll-y enhanced show-scrollbar="{{false}}"
      scroll-into-view="{{'chapter-' + currentNodeId}}"
    >
      <block wx:for="{{fullChapters}}" wx:key="id" wx:for-item="chapter" wx:for-index="ci">
        <view class="page-classic-reader__chapter" id="chapter-{{chapter.id}}">
          <!-- 章目标题 -->
          <view class="page-classic-reader__chapter-header">
            <view class="page-classic-reader__chapter-divider"></view>
            <text class="page-classic-reader__chapter-title">{{chapter.title}}</text>
            <view class="page-classic-reader__chapter-divider"></view>
          </view>

          <!-- 遍历段落 -->
          <block wx:for="{{chapter.paragraphs}}" wx:key="*this" wx:for-item="para" wx:for-index="pi">
            <view class="page-classic-reader__paragraph">
              <!-- 原文行 -->
              <view class="page-classic-reader__text-line">
                <block wx:for="{{paragraphSegments[ci][pi]}}" wx:key="*this" wx:for-item="seg">
                  <text
                    wx:if="{{seg.isGlossary}}"
                    class="page-classic-reader__gloss-word"
                    data-paragraph-index="{{pi}}"
                    data-word="{{seg.word}}"
                    data-explanation="{{seg.explanation}}"
                    catchtap="onTapGlossaryWord"
                    hover-class="page-classic-reader__gloss-word--hover"
                  >{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-classic-reader__pinyin">({{seg.pinyin}})</text></text>
                  <text wx:else>{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-classic-reader__pinyin">({{seg.pinyin}})</text></text>
                </block>
              </view>

              <!-- 译文 -->
              <view class="page-classic-reader__translation">
                <text>{{para.translation}}</text>
              </view>
            </view>
          </block>
        </view>
      </block>

      <view class="page-classic-reader__scroll-footer">
        <view class="page-classic-reader__scroll-footer-line"></view>
        <text class="page-classic-reader__scroll-footer-text">—— 终 ——</text>
        <view class="page-classic-reader__scroll-footer-line"></view>
      </view>
    </scroll-view>

    <!-- ========================================== -->
    <!-- chunked 加载模式：单章内容 -->
    <!-- ========================================== -->
    <scroll-view
      wx:elif="{{meta.loadMode === 'chunked'}}"
      class="page-classic-reader__scroll-body"
      scroll-y enhanced show-scrollbar="{{false}}"
    >
      <!-- 内容加载中 -->
      <view wx:if="{{contentLoading}}" class="page-classic-reader__content-loading">
        <text>加载中...</text>
      </view>

      <!-- 无选中内容 -->
      <view wx:elif="{{!currentContent}}" class="page-classic-reader__content-empty">
        <text class="page-classic-reader__content-empty-icon">📖</text>
        <text class="page-classic-reader__content-empty-text">点击上方目录选择章节开始阅读</text>
      </view>

      <!-- 内容渲染 -->
      <block wx:else>
        <!-- 章目标题 -->
        <view class="page-classic-reader__chapter-header">
          <view class="page-classic-reader__chapter-divider"></view>
          <text class="page-classic-reader__chapter-title">{{currentContent.title}}</text>
          <view class="page-classic-reader__chapter-divider"></view>
        </view>

        <!-- 段落（章节型） -->
        <block wx:if="{{currentContent.paragraphs && currentContent.paragraphs.length > 0}}">
          <block wx:for="{{currentContent.paragraphs}}" wx:key="*this" wx:for-item="para" wx:for-index="pi">
            <view class="page-classic-reader__paragraph">
              <view class="page-classic-reader__text-line">
                <block wx:for="{{paragraphSegments[pi]}}" wx:key="*this" wx:for-item="seg">
                  <text
                    wx:if="{{seg.isGlossary}}"
                    class="page-classic-reader__gloss-word"
                    data-paragraph-index="{{pi}}"
                    data-word="{{seg.word}}"
                    data-explanation="{{seg.explanation}}"
                    catchtap="onTapGlossaryWord"
                    hover-class="page-classic-reader__gloss-word--hover"
                  >{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-classic-reader__pinyin">({{seg.pinyin}})</text></text>
                  <text wx:else>{{seg.text}}<text wx:if="{{seg.pinyin}}" class="page-classic-reader__pinyin">({{seg.pinyin}})</text></text>
                </block>
              </view>

              <view class="page-classic-reader__translation">
                <text>{{para.translation}}</text>
              </view>
            </view>
          </block>
        </block>

        <!-- 纯文本（选集型/卷帙型） -->
        <block wx:else>
          <view class="page-classic-reader__text-line">
            <text>{{currentContent.text || ''}}</text>
          </view>
          <view wx:if="{{currentContent.translation}}" class="page-classic-reader__translation">
            <text>{{currentContent.translation}}</text>
          </view>
        </block>

        <!-- 上下篇导航 -->
        <view class="page-classic-reader__chapter-nav" wx:if="{{tocNodes.length > 1}}">
          <view class="page-classic-reader__chapter-nav-btn" bindtap="onTapPrevChapter">
            <text>◀ 上一篇</text>
          </view>
          <view class="page-classic-reader__chapter-nav-btn" bindtap="onTapNextChapter">
            <text>下一篇 ▶</text>
          </view>
        </view>

        <!-- 底部标记 -->
        <view class="page-classic-reader__scroll-footer">
          <view class="page-classic-reader__scroll-footer-line"></view>
          <text class="page-classic-reader__scroll-footer-text">—— 本章完 ——</text>
          <view class="page-classic-reader__scroll-footer-line"></view>
        </view>
      </block>
    </scroll-view>

    <!-- ========================================== -->
    <!-- 目录面板（侧滑覆盖层） -->
    <!-- ========================================== -->
    <view class="page-classic-reader__toc-mask {{showTocPanel ? 'page-classic-reader__toc-mask--show' : ''}}" bindtap="onCloseToc"></view>
    <view class="page-classic-reader__toc-panel {{showTocPanel ? 'page-classic-reader__toc-panel--show' : ''}}">
      <view class="page-classic-reader__toc-header">
        <text class="page-classic-reader__toc-title">目录</text>
        <view class="page-classic-reader__toc-close" bindtap="onCloseToc">
          <text>✕</text>
        </view>
      </view>

      <!-- author nav mode: 作者分组浏览 -->
      <block wx:if="{{meta.navMode === 'author'}}">
        <!-- 一级：作者列表 -->
        <block wx:if="{{authorLevel === 0}}">
          <block wx:for="{{tocNodes}}" wx:key="id">
            <view
              class="page-classic-reader__author-group"
              data-group-id="{{item.id}}"
              bindtap="onTapAuthor"
              hover-class="page-classic-reader__author-group--hover"
            >
              <text class="page-classic-reader__author-name">{{item.title}}</text>
              <text class="page-classic-reader__author-count">{{item.children ? item.children.length : 0}}首</text>
            </view>
          </block>
        </block>
        <!-- 二级：该作者诗篇列表 -->
        <block wx:elif="{{authorLevel === 1}}">
          <view class="page-classic-reader__author-back" bindtap="onBackToAuthorList" hover-class="page-classic-reader__author-back--hover">
            <text>‹ 返回作者列表</text>
          </view>
          <view class="page-classic-reader__author-subtitle">
            <text>{{selectedAuthor}} · {{authorEntries.length}}首</text>
          </view>
          <block wx:for="{{authorEntries}}" wx:key="id">
            <view
              class="page-classic-reader__toc-item {{currentNodeId === item.id ? 'page-classic-reader__toc-item--active' : ''}}"
              data-node-id="{{item.id}}"
              data-is-leaf="{{item.isLeaf}}"
              bindtap="onTapAuthorEntry"
              hover-class="page-classic-reader__toc-item--hover"
            >
              <text class="page-classic-reader__toc-item-text">{{item.title}}</text>
              <text class="page-classic-reader__toc-dot {{listenedNodeIds[item.id] ? 'page-classic-reader__toc-dot--listened' : 'page-classic-reader__toc-dot--fresh'}}">{{listenedNodeIds[item.id] ? '●' : '○'}}</text>
            </view>
          </block>
        </block>
      </block>

      <!-- 目录列表（非 author 模式） -->
      <scroll-view class="page-classic-reader__toc-body" scroll-y enhanced show-scrollbar="{{false}}">
        <block wx:if="{{meta.navMode !== 'author'}}">
        <block wx:for="{{tocNodes}}" wx:key="id">
          <!-- 手风琴模式：非叶子节点可展开 -->
          <block wx:if="{{meta.navMode === 'accordion' && item.children && item.children.length > 0}}">
            <view class="page-classic-reader__toc-group">
              <view
                class="page-classic-reader__toc-group-title {{item.level > 0 ? 'page-classic-reader__toc-group-title--child' : ''}}"
                data-node-id="{{item.id}}"
              >
                <text>{{item.title}}</text>
                <text class="page-classic-reader__toc-group-arrow">▾</text>
              </view>
              <block wx:for="{{item.children}}" wx:key="id" wx:for-item="child">
                <view
                  class="page-classic-reader__toc-item page-classic-reader__toc-item--child {{currentNodeId === child.id ? 'page-classic-reader__toc-item--active' : ''}}"
                  data-node-id="{{child.id}}"
                  data-is-leaf="{{child.isLeaf}}"
                  bindtap="onTapTocNode"
                >
                  <text>{{child.title}}</text>
                  <text class="page-classic-reader__toc-dot {{listenedNodeIds[child.id] ? 'page-classic-reader__toc-dot--listened' : 'page-classic-reader__toc-dot--fresh'}}">{{listenedNodeIds[child.id] ? '●' : '○'}}</text>
                </view>
              </block>
            </view>
          </block>
          <!-- 非手风琴 / 叶子节点：直接列表项 -->
          <block wx:else>
            <view
              class="page-classic-reader__toc-item {{item.level > 0 ? 'page-classic-reader__toc-item--child' : ''}} {{currentNodeId === item.id ? 'page-classic-reader__toc-item--active' : ''}} {{!item.isLeaf ? 'page-classic-reader__toc-item--disabled' : ''}}"
              data-node-id="{{item.id}}"
              data-is-leaf="{{item.isLeaf}}"
              bindtap="onTapTocNode"
            >
              <text class="page-classic-reader__toc-item-text">{{item.title}}</text>
              <text wx:if="{{item.isLeaf}}" class="page-classic-reader__toc-dot {{listenedNodeIds[item.id] ? 'page-classic-reader__toc-dot--listened' : 'page-classic-reader__toc-dot--fresh'}}">{{listenedNodeIds[item.id] ? '●' : '○'}}</text>
              <text wx:elif="{{!item.isLeaf}}" class="page-classic-reader__toc-item-hint">整理中</text>
            </view>
          </block>
        </block>
        </block>
      </scroll-view>
    </view>

    <!-- 创作背景弹窗 -->
    <view class="page-classic-reader__bg-overlay" wx:if="{{showBackground}}" bindtap="onCloseBackground">
      <view class="page-classic-reader__bg-modal" catchtap="">
        <view class="page-classic-reader__bg-header">
          <text class="page-classic-reader__bg-title">背景介绍</text>
          <view class="page-classic-reader__bg-close" bindtap="onCloseBackground">
            <text>✕</text>
          </view>
        </view>
        <scroll-view class="page-classic-reader__bg-body" scroll-y enhanced show-scrollbar="{{false}}">
          <text class="page-classic-reader__bg-text">{{currentContent.background}}</text>
        </scroll-view>
      </view>
    </view>

    <!-- 错误反馈浮层 -->
    <view class="page-classic-reader__feedback-mask" wx:if="{{showFeedbackPanel}}" bindtap="onCloseFeedback"></view>
    <view class="page-classic-reader__feedback-panel {{showFeedbackPanel ? 'page-classic-reader__feedback-panel--show' : ''}}">
      <view class="page-classic-reader__feedback-header">
        <text class="page-classic-reader__feedback-title">🙋 反馈错误</text>
        <view class="page-classic-reader__feedback-close" bindtap="onCloseFeedback">
          <text>✕</text>
        </view>
      </view>

      <view class="page-classic-reader__feedback-body">
        <view class="page-classic-reader__feedback-label">错误类型</view>
        <view class="page-classic-reader__feedback-categories">
          <view
            wx:for="{{['sentence_text','translation','annotation','other']}}"
            wx:key="*this"
            wx:for-item="cat"
            class="page-classic-reader__feedback-cat {{feedbackCategory === cat ? 'page-classic-reader__feedback-cat--active' : ''}}"
            data-category="{{cat}}"
            bindtap="onSelectFeedbackCategory"
          >
            <text wx:if="{{cat === 'sentence_text'}}">原文有误</text>
            <text wx:elif="{{cat === 'translation'}}">译文有误</text>
            <text wx:elif="{{cat === 'annotation'}}">标注有误</text>
            <text wx:else>其他</text>
          </view>
        </view>

        <view class="page-classic-reader__feedback-label">详细说明（选填）</view>
        <textarea
          class="page-classic-reader__feedback-textarea"
          placeholder="请描述具体哪里有问题..."
          value="{{feedbackDescription}}"
          maxlength="200"
          bindinput="onFeedbackDescriptionInput"
        />

        <view class="page-classic-reader__feedback-submit-wrap">
          <view class="page-classic-reader__feedback-submit {{feedbackSubmitting ? 'page-classic-reader__feedback-submit--loading' : ''}}" bindtap="onSubmitFeedback">
            <text>{{feedbackSubmitting ? '提交中...' : '提交反馈'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 典故注释底部浮层 -->
    <block wx:if="{{glossaryPopup}}">
      <view
        class="page-classic-reader__gloss-overlay"
        bindtap="onDismissGlossaryPopup"
      ></view>
      <view class="page-classic-reader__gloss-panel">
        <view class="page-classic-reader__gloss-panel-bar" bindtap="onDismissGlossaryPopup">
          <view class="page-classic-reader__gloss-panel-handle"></view>
        </view>
        <view class="page-classic-reader__gloss-panel-body">
          <text class="page-classic-reader__gloss-panel-word">{{glossaryPopup.word}}</text>
          <text class="page-classic-reader__gloss-panel-explanation">{{glossaryPopup.explanation}}</text>
        </view>
      </view>
    </block>
  </block>

  <!-- +XP 动效 -->
  <view wx:if="{{xpAnimation}}" class="page-classic-reader__xp-animation" bindtap="onDismissXpAnimation">
    <text class="page-classic-reader__xp-animation-text">+{{xpAnimation.xp}} XP 🎧</text>
  </view>
</view>
