<view class="page-settings">
  <view class="page-settings__section"><view class="page-settings__section-title">每日学习</view>
    <view class="page-settings__card">
      <view class="page-settings__row"><text class="page-settings__label">每日新学词数</text>
        <picker mode="selector" range="{{newWordsRange}}" value="{{newWordsRange.indexOf(dailyNewWords)}}" bindchange="onNewWordsChange"><view class="page-settings__picker-value"><text>{{dailyNewWords}}</text><text class="page-settings__picker-arrow">›</text></view></picker></view>
      <view class="page-settings__row"><text class="page-settings__label">每日复习词数</text>
        <picker mode="selector" range="{{reviewWordsRange}}" value="{{dailyReviewWords - 1}}" bindchange="onReviewWordsChange"><view class="page-settings__picker-value"><text>{{dailyReviewWords}}</text><text class="page-settings__picker-arrow">›</text></view></picker></view>
    </view>
  </view>
  <view class="page-settings__section"><view class="page-settings__section-title">学习偏好</view>
    <view class="page-settings__card">
      <view class="page-settings__row"><text class="page-settings__label">自动播放语音</text><switch checked="{{autoPlayAudio}}" bindchange="onToggleAutoPlay" color="#4a6a5e" /></view>
      <view class="page-settings__row"><text class="page-settings__label">答题音效</text><switch checked="{{answerSound}}" bindchange="onToggleAnswerSound" color="#4a6a5e" /></view>
      <view class="page-settings__row"><text class="page-settings__label">学习顺序</text>
        <picker mode="selector" range="{{studyOrderOptions}}" value="{{studyOrder}}" bindchange="onStudyOrderChange"><view class="page-settings__picker-value"><text>{{studyOrderOptions[studyOrder]}}</text><text class="page-settings__picker-arrow">›</text></view></picker></view>
      <view class="page-settings__row"><text class="page-settings__label">错题移出阈值</text>
        <picker mode="selector" range="{{['1次','2次','3次']}}" value="{{['1次','2次','3次'].indexOf(mistakeThreshold + '次')}}" bindchange="onMistakeThresholdChange"><view class="page-settings__picker-value"><text>{{mistakeThreshold}}次答对后移出</text><text class="page-settings__picker-arrow">›</text></view></picker></view>
    </view>
  </view>
  <view class="page-settings__section"><view class="page-settings__section-title">关于</view>
    <view class="page-settings__card"><view class="page-settings__row"><text class="page-settings__label">版本</text><text class="page-settings__value">v{{version}}</text></view></view>
  </view>

  <!-- 恢复数据区域（暂时隐藏，后续开放）
  <view class="page-settings__recover" wx:if="{{recoveryDeadline}}">
    <view class="page-settings__recover-card">
      <view class="page-settings__recover-icon">📋</view>
      <view class="page-settings__recover-text">
        <text class="page-settings__recover-title">数据已清除，如需回退可恢复</text>
      </view>
      <button class="page-settings__recover-btn" bindtap="onRecoverData">恢复数据</button>
    </view>
  </view>
  -->

  <view class="page-settings__danger"><button class="page-settings__danger-btn" bindtap="onClearData">清除学习数据</button></view>

  <view class="page-settings__overlay" wx:if="{{clearing}}">
    <view class="page-settings__overlay-mask"></view>
    <view class="page-settings__overlay-content">
      <view class="page-settings__overlay-spinner"></view>
      <text class="page-settings__overlay-text">处理中...</text>
    </view>
  </view>
</view>
