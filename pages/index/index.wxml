<!-- 首页 · 学习 Tab -->
<view class="page-index">

  <!-- ===== 加载态 ===== -->
  <view wx:if="{{loading}}" class="page-index__loading">
    <view class="page-index__loading-spinner"></view>
    <text class="page-index__loading-text">加载中...</text>
  </view>

  <!-- ===== 主体内容 ===== -->
  <block wx:else>

    <!-- -------- 搜索栏（置顶） -------- -->
    <view class="page-index__search-bar" bindtap="onTapSearch" hover-class="page-index__search-bar--hover">
      <text class="page-index__search-bar-icon">🔍</text>
      <text class="page-index__search-bar-placeholder">搜索文言字词</text>
    </view>

    <!-- -------- 顶部问候区域 -------- -->
    <view class="page-index__header">
      <view class="page-index__header-top">
        <view class="page-index__header-left">
          <text class="page-index__greeting">你好，{{nickName || '学友'}}</text>
        </view>
        <view
          wx:if="{{nextBadge}}"
          class="page-index__next-badge"
          hover-class="page-index__next-badge--active"
          bindtap="onTapBadges"
        >
          <text class="page-index__next-badge-icon">{{nextBadge.icon}}</text>
          <view class="page-index__next-badge-info">
            <text class="page-index__next-badge-name">{{nextBadge.name}}</text>
            <text class="page-index__next-badge-gap">
              <block wx:if="{{nextBadge.gap === 0}}">即将获得</block>
              <block wx:else>还差{{nextBadge.gap}}{{nextBadge.gapLabel}}</block>
            </text>
          </view>
        </view>
        <view
          wx:else
          class="page-index__badges-btn"
          hover-class="page-index__badges-btn--active"
          bindtap="onTapBadges"
        >勋章墙</view>
      </view>
      <view class="page-index__slogan">
        <block wx:if="{{checkedIn}}">
          <text class="page-index__slogan-icon">✅</text>
          <text>已打卡 · 连续打卡 {{streak}} 天</text>
        </block>
        <block wx:else>
          <text class="page-index__slogan-icon">🔥</text>
          <text>连续打卡 {{streak}} 天</text>
        </block>
      </view>
    </view>

    <!-- -------- 词书切换卡片 -------- -->
    <view wx:if="{{currentBook}}" class="page-index__book-card">
      <!-- 标题行（词书+进度同行） -->
      <view class="page-index__book-header">
        <view
          class="page-index__book-selector"
          hover-class="page-index__book-selector--hover"
          bindtap="onTapBookSelector"
        >
          <text class="page-index__book-icon">📚</text>
          <text class="page-index__book-name">{{currentBook.name}}</text>
          <text class="page-index__book-arrow">›</text>
        </view>
        <view class="page-index__book-stats">
          <text class="page-index__book-stats-label">已掌握</text>
          <text class="page-index__book-stats-value">{{progress.mastered}} / {{progress.total}}</text>
          <text class="page-index__book-stats-percent">{{progress.percent}}%</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="page-index__progress-bar">
        <view
          class="page-index__progress-fill"
          style="width: {{progress.percent}}%;"
        ></view>
      </view>

      <!-- 掌握分布标签 -->
      <view class="page-index__book-distribution">
        <view
          wx:for="{{progress.distribution}}"
          wx:key="key"
          class="page-index__dist-tag page-index__dist-tag--{{item.key}}"
          data-tab="{{item.key}}"
          catch:tap="onTapDistribution"
          hover-class="page-index__dist-tag--active"
        >{{item.label}} {{item.count}}</view>
      </view>
    </view>

    <!-- 词书空状态 -->
    <view wx:else class="page-index__book-card page-index__book-card--empty">
      <text class="page-index__empty-icon">📖</text>
      <text class="page-index__empty-text">暂未选择词书</text>
      <view
        class="page-index__empty-link"
        hover-class="page-index__empty-link--active"
        bindtap="onTapBookSelector"
      >去选择</view>
    </view>

    <!-- -------- 今日任务区 -------- -->
    <view class="page-index__task-section">
      <view class="page-index__task-header">
        <text class="page-index__task-title">今日任务</text>
        <view
          class="page-index__task-settings"
          hover-class="page-index__task-settings--hover"
          catch:tap="onTapSettings"
        >
          <text class="page-index__task-settings-icon">🎛️</text>
          <text class="page-index__task-settings-text">学习设置</text>
        </view>
      </view>

      <!-- 任务统计 -->
      <view class="page-index__task-row">
        <view class="page-index__task-stat">
          <text class="page-index__task-stat-icon">📖</text>
          <text class="page-index__task-stat-text">新学</text>
          <text class="page-index__task-stat-num">{{todayTask.newWords}}</text>
          <text class="page-index__task-stat-unit">个</text>
        </view>
        <view class="page-index__task-stat">
          <text class="page-index__task-stat-icon">🔄</text>
          <text class="page-index__task-stat-text">复习</text>
          <text class="page-index__task-stat-num">{{todayTask.reviewWords}}</text>
          <text class="page-index__task-stat-unit">个</text>
        </view>
      </view>

      <!-- 预估时间 -->
      <view class="page-index__task-time">
        <text class="page-index__task-time-icon">⏱</text>
        <text>预计 {{todayTask.estimatedMinutes}} 分钟</text>
      </view>

      <!-- 开始学习 CTA -->
      <button
        class="page-index__task-btn"
        hover-class="page-index__task-btn--hover"
        bindtap="onTapStartLearning"
      >开 始 学 习</button>

      <view class="page-index__task-tip">艾宾浩斯遗忘曲线，智能安排复习节奏</view>
    </view>

    <!-- -------- 快捷入口区 -------- -->
    <view class="page-index__entry-section">
      <!-- 生词本 -->
      <view
        class="page-index__entry-card"
        hover-class="page-index__entry-card--active"
        bindtap="onTapVocabulary"
      >
        <text class="page-index__entry-icon">📝</text>
        <text class="page-index__entry-label">生词本</text>
        <text class="page-index__entry-desc">掌握分布</text>
      </view>
      <!-- 错题本 -->
      <view
        class="page-index__entry-card"
        hover-class="page-index__entry-card--active"
        bindtap="onTapMistakeBook"
      >
        <text class="page-index__entry-icon">📋</text>
        <text class="page-index__entry-label">错题本</text>
        <text class="page-index__entry-desc">已收录 {{mistakeCount}} 条</text>
      </view>
      <!-- 打卡日历 -->
      <view
        class="page-index__entry-card"
        hover-class="page-index__entry-card--active"
        bindtap="onTapCalendar"
      >
        <text class="page-index__entry-icon">📅</text>
        <text class="page-index__entry-label">打卡日历</text>
        <text class="page-index__entry-desc">连续打卡 {{streak}} 天</text>
      </view>
    </view>

  </block>

  <!-- 学习码门禁弹窗：打卡满N天需关注公众号验证码 -->
  <view class="page-index__gate-overlay" wx:if="{{showGate}}">
    <view class="page-index__gate-modal" catchtap="noop">

      <!-- ===== 阶段一：引导关注公众号 ===== -->
      <block wx:if="{{gateStep === 1}}">
        <text class="page-index__gate-emoji">{{codeExpired ? '⏰' : '🎉'}}</text>
        <text class="page-index__gate-title">{{codeExpired ? '好久不见！请更新学习码' : '你已经坚持学习了 ' + shareGateDays + ' 天！'}}</text>
        <text class="page-index__gate-desc">
          {{codeExpired ? '关注公众号，获取新的学习码' : '关注公众号，获取永久学习码'}}
        </text>
        <!-- 服务号二维码占位（后续替换为真实二维码） -->
        <view class="page-index__gate-qrcode">
          <image
            class="page-index__gate-qrcode-img"
            src="/assets/qrcode-mp.jpg"
            mode="aspectFit"
          />
        </view>
        <text class="page-index__gate-qrcode-hint">长按或扫码关注公众号</text>
        <view
          class="page-index__gate-btn"
          hover-class="page-index__gate-btn--hover"
          bindtap="onGoToInputCode"
        >我已关注，输入学习码</view>
      </block>

      <!-- ===== 阶段二：输入学习码 ===== -->
      <block wx:if="{{gateStep === 2}}">
        <text class="page-index__gate-emoji">🔑</text>
        <text class="page-index__gate-title">输入学习码</text>
        <text class="page-index__gate-desc">
          请在公众号回复的消息中找到您的学习码并输入
        </text>
        <view class="page-index__gate-input-wrap">
          <input
            class="page-index__gate-input page-index__gate-input--full"
            type="digit"
            maxlength="6"
            placeholder="输入6位数字学习码"
            value="{{redeemCode}}"
            bindinput="onInputCode"
          />
        </view>
        <text
          wx:if="{{codeError}}"
          class="page-index__gate-error"
        >{{codeError}}</text>
        <view
          class="page-index__gate-btn"
          hover-class="page-index__gate-btn--hover"
          bindtap="onVerifyCode"
        >确认验证</view>
        <view
          class="page-index__gate-back"
          hover-class="page-index__gate-back--active"
          bindtap="onGoBackToQrcode"
        >还没关注？返回查看公众号</view>
      </block>

      <!-- ===== 阶段三：签金石契（仅首次） ===== -->
      <block wx:if="{{gateStep === 3}}">
        <text class="page-index__gate-emoji">📜</text>
        <text class="page-index__gate-title page-index__gate-title--pact">金石契</text>
        <text class="page-index__gate-pact-text">君以分享托付文言雀</text>
        <text class="page-index__gate-pact-text">文言雀亦以赤诚报君</text>
        <text class="page-index__gate-pact-text page-index__gate-pact-text--bold">此约既成，金石不渝</text>
        <!-- 签订契约复选框 -->
        <view class="page-index__gate-pact-check" bindtap="onTogglePactCheck">
          <text class="page-index__gate-pact-check-finger">👉</text>
          <view class="page-index__gate-pact-check-box {{pactChecked ? 'page-index__gate-pact-check-box--checked' : ''}}">
            <text wx:if="{{pactChecked}}" class="page-index__gate-pact-check-mark">✓</text>
          </view>
          <text class="page-index__gate-pact-check-label">余今签契，行之以诚</text>
        </view>
        <view
          class="page-index__gate-btn page-index__gate-btn--pact {{pactChecked ? '' : 'page-index__gate-btn--disabled'}}"
          hover-class="page-index__gate-btn--hover"
          bindtap="onSignPact"
        >签订契约</view>
        <text class="page-index__gate-pact-footer">契约既签，永久免费学习</text>
      </block>

    </view>
  </view>

</view>
